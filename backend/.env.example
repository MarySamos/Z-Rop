# Application Configuration
APP_NAME=BankAgent-Pro
APP_VERSION=1.0.0
DEBUG=True

# Database Configuration (必需)
DATABASE_URL=sqlite:///./bank_agent.db

# Security Configuration (必需)
SECRET_KEY=your-secret-key-change-this-to-something-secure
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI API Configuration (必需)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1

# Zhipu AI API (可选 - 如果使用智谱AI)
ZHIPU_API_KEY=
ZHIPU_BASE_URL=

# LLM Configuration
LLM_MODEL=glm-4
LLM_API_BASE=https://open.bigmodel.cn/api/paas/v4/

# LangSmith Tracing (可选)
LANGSMITH_PROJECT=
LANGSMITH_API_KEY=

# Checkpoint Configuration
CHECKPOINT_TYPE=memory
CHECKPOINT_DB_URL=
